# Copy to .env and fill in. The framework reads these at runtime.

# Your API key for the selected provider.
LLM_API_KEY=

# Which backend complete()/embed() target: openai | anthropic
LLM_PROVIDER=openai

# --- Optional overrides ---
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_EMBED_MODEL=text-embedding-3-small
# Anthropic has no embeddings endpoint; point embeddings at an OpenAI-compatible
# provider if you need embed() while using Anthropic for chat:
# LLM_EMBED_PROVIDER=openai
